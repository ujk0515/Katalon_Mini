{
  "name": "katalon-mini",
  "version": "0.1.0",
  "description": "Lightweight web test automation tool inspired by Katalon Studio",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "node esbuild.main.mjs",
    "dev:renderer": "vite",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "node esbuild.main.mjs",
    "build:renderer": "vite build",
    "start": "electron dist/main/index.js",
    "postinstall": "npx playwright install chromium",
    "clean": "node -e \"const fs=require('fs');['dist','release'].forEach(d=>{if(fs.existsSync(d))fs.rmSync(d,{recursive:true,force:true})})\"",
    "package": "electron-builder"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "chevrotain": "^11.0.3",
    "playwright": "^1.45.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^10.0.0",
    "zustand": "^4.5.4"
  },
  "build": {
    "appId": "com.katalon.mini",
    "productName": "Katalon Mini",
    "files": [
      "dist/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    }
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^30.1.0",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.27.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.2",
    "vite": "^5.3.1"
  }
}
